{
  "name": "@dynamic-scroll/core",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.2.1",
  "description": "Headless virtual scroll library with pre-render measurement for pixel-perfect accuracy",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heogeon0/dynamic-scroll.git",
    "directory": "packages/core"
  },
  "keywords": [
    "virtual-scroll",
    "react",
    "dynamic-height",
    "infinite-scroll",
    "chat",
    "headless"
  ],
  "license": "MIT"
}
